generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DOCTOR
  ADMIN
  PATIENT
  NURSE
}

enum OAuthProvider {
  GOOGLE
  MICROSOFT
}

// ─── Tenant-specific models ───────────────────────────────────────────────────
// All queried via SET LOCAL search_path TO tenant_xxx in PrismaService.withTenantSchema()

model User {
  id             String    @id @default(uuid())
  tenantId       String
  role           UserRole
  name           String
  twilioIdentity String?
  isActive       Boolean   @default(true)
  emailVerifiedAt DateTime?

  doctorProfile  DoctorProfile?
  adminProfile   AdminProfile?
  patientProfile PatientProfile?
  nurseProfile   NurseProfile?

  refreshTokens                 RefreshToken[]
  consultationSessionsAsDoctor  ConsultationSession[]      @relation("ConsultationSessionDoctor")
  consultationSessionsAsPatient ConsultationSession[]      @relation("ConsultationSessionPatient")
  consultationSessionsCreated   ConsultationSession[]      @relation("ConsultationSessionCreatedBy")
  consultationSessionsAsNurse   ConsultationSession[]      @relation("ConsultationSessionNurse")
  consultationSessionAudits     ConsultationSessionAudit[] @relation("ConsultationSessionActor")
  consultationNotesAsDoctor     ConsultationNote[]         @relation("ConsultationNoteDoctor")
  consultationNotesAsPatient    ConsultationNote[]         @relation("ConsultationNotePatient")
  consultationNotesAsNurse      ConsultationNote[]         @relation("ConsultationNoteNurse")
  oauthAccounts                 OauthAccount[]
  authAuditLogs                 AuthAuditLog[]
  pendingEmailChanges           PendingEmailChange[]
  pendingPasswordResets         PendingPasswordReset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([twilioIdentity, tenantId])
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([role])
  @@index([isActive])
}

model DoctorProfile {
  id           String  @id @default(uuid())
  tenantId     String
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName       String
  email          String
  phone          String
  passwordHash   String?
  license        String
  profilePicture String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
  @@unique([phone, tenantId])
  @@unique([license, tenantId])
  @@index([tenantId])
  @@index([license])
}

model AdminProfile {
  id      String @id @default(uuid())
  tenantId String
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName       String
  email          String
  phone          String
  passwordHash   String?
  adminId        String
  profilePicture String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
  @@unique([phone, tenantId])
  @@unique([adminId, tenantId])
  @@index([tenantId])
  @@index([adminId])
}

model PatientProfile {
  id       String @id @default(uuid())
  tenantId String
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName       String
  email          String
  phone          String
  passwordHash   String?
  bornDate       DateTime
  profilePicture String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
  @@unique([phone, tenantId])
  @@index([tenantId])
}

model NurseProfile {
  id       String @id @default(uuid())
  tenantId String
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName       String
  email          String
  phone          String
  passwordHash   String?
  nurseId        String
  profilePicture String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
  @@unique([phone, tenantId])
  @@unique([nurseId, tenantId])
  @@index([tenantId])
  @@index([nurseId])
}

model OauthAccount {
  id             String        @id @default(uuid())
  tenantId       String
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       OAuthProvider
  providerUserId String
  email          String?
  createdAt      DateTime      @default(now())

  @@unique([provider, providerUserId, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@map("OAuthAccount")
}

model RefreshToken {
  id       String @id @default(uuid())
  tenantId String
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String  @unique
  userAgent String?
  ip        String?

  revokedAt DateTime?

  replacedByTokenId String?       @unique
  replacedByToken   RefreshToken? @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [id])
  replacesToken     RefreshToken? @relation("RefreshTokenReplacement")

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PendingEmailChange {
  id       String @id @default(uuid())
  tenantId String
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  newEmail  String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
  @@index([newEmail])
}

model PendingPasswordReset {
  id       String @id @default(uuid())
  tenantId String
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
}

model LicenseWhitelist {
  id        String   @id @default(uuid())
  tenantId  String
  license   String

  createdAt DateTime @default(now())

  @@unique([license, tenantId])
  @@index([tenantId])
}

model AdminIdWhitelist {
  id        String   @id @default(uuid())
  tenantId  String
  adminId   String

  createdAt DateTime @default(now())

  @@unique([adminId, tenantId])
  @@index([tenantId])
}

model NurseIdWhitelist {
  id        String   @id @default(uuid())
  tenantId  String
  nurseId   String

  createdAt DateTime @default(now())

  @@unique([nurseId, tenantId])
  @@index([tenantId])
}

model MrnWhitelist {
  id        String   @id @default(uuid())
  tenantId  String
  mrn       String

  createdAt DateTime @default(now())

  @@unique([mrn, tenantId])
  @@index([tenantId])
}

model AuthAuditLog {
  id        String     @id @default(uuid())
  tenantId  String
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String?
  action    AuthAction
  success   Boolean    @default(false)
  ip        String?
  userAgent String?
  createdAt DateTime   @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ConsultationSession {
  sessionId String @id @map("session_id")
  tenantId  String

  patientId String @map("patient_id")
  patient   User   @relation("ConsultationSessionPatient", fields: [patientId], references: [id], onDelete: Restrict)

  doctorId String @map("doctor_id")
  doctor   User   @relation("ConsultationSessionDoctor", fields: [doctorId], references: [id], onDelete: Restrict)

  sessionType      SessionType      @map("session_type")
  consultationMode ConsultationMode @map("consultation_mode")

  scheduledDate      DateTime  @db.Date @map("scheduled_date")
  scheduledStartTime DateTime  @map("scheduled_start_time")
  durationMinutes    Int?      @map("duration_minutes")
  scheduledEndTime   DateTime? @map("scheduled_end_time")

  sessionStatus SessionStatus @default(CREATED) @map("session_status")

  createdBy      String @map("created_by")
  createdByAdmin User   @relation("ConsultationSessionCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)

  nurseId String? @map("nurse_id")
  nurse   User?   @relation("ConsultationSessionNurse", fields: [nurseId], references: [id], onDelete: SetNull)

  roomName      String  @map("room_name")
  twilioRoomSid String? @map("twilio_room_sid")

  doctorIdentity  String? @map("doctor_identity")
  patientIdentity String? @map("patient_identity")
  patientName     String? @map("patient_name")

  patientCountryCode String? @map("patient_country_code")
  patientCountry     String? @map("patient_country")
  patientProvince    String? @map("patient_province")
  patientCity        String? @map("patient_city")
  patientLatitude    Float?  @map("patient_latitude")
  patientLongitude   Float?  @map("patient_longitude")

  nurseJoinedAt  DateTime? @map("nurse_joined_at")
  nurseIdentity  String?   @map("nurse_identity")

  doctorJoinedAt  DateTime? @map("doctor_joined_at")
  patientJoinedAt DateTime? @map("patient_joined_at")
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")

  recordingEnabled     Boolean   @default(false) @map("recording_enabled")
  recordingStatus      String?   @map("recording_status")
  recordingStartedAt   DateTime? @map("recording_started_at")
  recordingCompletedAt DateTime? @map("recording_completed_at")

  compositionSid       String?   @map("composition_sid")
  compositionStatus    String?   @map("composition_status")
  compositionStartedAt DateTime? @map("composition_started_at")
  compositionReadyAt   DateTime? @map("composition_ready_at")

  mediaUrl     String? @map("media_url")
  mediaFormat  String? @map("media_format")
  durationSec  Int?    @map("duration_sec")
  errorMessage String? @map("error_message")

  consultationNote ConsultationNote?
  audits           ConsultationSessionAudit[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([roomName, tenantId])
  @@unique([twilioRoomSid, tenantId])
  @@unique([compositionSid, tenantId])
  @@index([tenantId])
  @@index([tenantId, doctorId, scheduledStartTime])
  @@index([tenantId, patientId, scheduledStartTime])
  @@index([doctorId])
  @@index([patientId])
  @@index([nurseId])
  @@index([createdBy])
  @@index([sessionStatus])
  @@index([scheduledStartTime])
  @@index([scheduledEndTime])
  @@index([doctorId, scheduledStartTime])
  @@index([patientId, scheduledStartTime])
  @@index([nurseId, scheduledStartTime])
  @@map("ConsultationSession")
}

model ConsultationNote {
  id                    String              @id @default(uuid())
  tenantId              String
  consultationSessionId String              @unique @map("consultation_session_id")
  consultationSession   ConsultationSession @relation(fields: [consultationSessionId], references: [sessionId], onDelete: Cascade)

  doctorId String
  doctor   User   @relation("ConsultationNoteDoctor", fields: [doctorId], references: [id], onDelete: Restrict)

  patientId String @map("patient_id")
  patient   User   @relation("ConsultationNotePatient", fields: [patientId], references: [id], onDelete: Restrict)

  nurseId String? @map("nurse_id")
  nurse   User?   @relation("ConsultationNoteNurse", fields: [nurseId], references: [id], onDelete: SetNull)

  transcriptRaw String?
  summary       String?

  subjective String?
  objective  String?
  assessment String?
  plan       String?

  aiStatus String?
  aiError  String?

  isFinalized Boolean   @default(false) @map("is_finalized")
  finalizedAt DateTime? @map("finalized_at")

  transcribedAt DateTime?
  summarizedAt  DateTime?
  aiModel       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([doctorId])
  @@index([patientId])
  @@index([nurseId])
  @@index([doctorId, createdAt(sort: Desc)])
  @@index([patientId, createdAt(sort: Desc)])
  @@index([consultationSessionId])
}

model ConsultationSessionAudit {
  id                    String              @id @default(uuid())
  tenantId              String
  consultationSessionId String              @map("consultation_session_id")
  consultationSession   ConsultationSession @relation(fields: [consultationSessionId], references: [sessionId], onDelete: Cascade)

  actorUserId String?   @map("actor_user_id")
  actorUser   User?     @relation("ConsultationSessionActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorRole   UserRole? @map("actor_role")
  action      String

  previousStatus SessionStatus? @map("previous_status")
  newStatus      SessionStatus? @map("new_status")
  metadata       Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([consultationSessionId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("ConsultationSessionAudit")
}

// ─── Public schema models (ephemeral / global) ────────────────────────────────
// These stay in default search_path (public). No withTenantSchema needed.

model SuperAdmin {
  id            String                   @id @default(uuid())
  email         String                   @unique
  name          String
  passwordHash  String
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  refreshTokens SuperAdminRefreshToken[]
}

model SuperAdminRefreshToken {
  id                String                  @id @default(uuid())
  superAdminId      String
  superAdmin        SuperAdmin              @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  tokenHash         String                  @unique
  userAgent         String?
  ip                String?
  revokedAt         DateTime?
  replacedByTokenId String?                 @unique
  replacedByToken   SuperAdminRefreshToken? @relation("SAReplacement", fields: [replacedByTokenId], references: [id])
  replacesToken     SuperAdminRefreshToken? @relation("SAReplacement")
  expiresAt         DateTime
  createdAt         DateTime                @default(now())

  @@index([superAdminId])
  @@index([expiresAt])
}

model TenantRegistry {
  id           String   @id
  slug         String   @unique
  name         String
  schemaName   String   @unique @map("schema_name")
  status       String   @default("active")
  adminEmail   String?  @map("admin_email")
  contactPhone String?  @map("contact_phone")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("tenant_registry")
}

model OauthState {
  id          String        @id @default(uuid())
  tenantSlug  String
  provider    OAuthProvider
  role        UserRole
  redirectUrl String?
  expiresAt   DateTime
  createdAt   DateTime      @default(now())

  @@index([expiresAt])
  @@map("OAuthState")
}

model OauthPending {
  id             String        @id @default(uuid())
  tenantSlug     String
  provider       OAuthProvider
  role           UserRole
  providerUserId String
  email          String
  name           String?
  expiresAt      DateTime
  createdAt      DateTime      @default(now())

  @@unique([provider, providerUserId, tenantSlug])
  @@index([email])
  @@index([expiresAt])
  @@map("OAuthPending")
}

model PendingRegistration {
  id           String   @id @default(uuid())
  tenantSlug   String
  role         UserRole
  email        String
  phone        String
  name         String
  passwordHash String

  license  String?
  adminId  String?
  nurseId  String?
  bornDate DateTime?

  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tenantSlug])
  @@index([email])
  @@index([phone])
  @@index([expiresAt])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SessionType {
  SCHEDULED
  INSTANT
}

enum ConsultationMode {
  VIDEO
  VOICE
}

enum SessionStatus {
  CREATED
  IN_CALL
  COMPLETED
  FAILED
}

enum AuthAction {
  REGISTER
  LOGIN
  LOGOUT
  REFRESH
  TOKEN_REVOKE
}
